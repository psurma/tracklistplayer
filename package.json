{
  "name": "tracklistplayer",
  "version": "1.22.2",
  "description": "DJ mix MP3 player with CUE sheet track detection and Spotify search",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "build": "electron-builder",
    "build:js": "esbuild src/app.js --bundle --outfile=public/app.bundle.js --format=iife",
    "watch:js": "esbuild src/app.js --bundle --outfile=public/app.bundle.js --format=iife --watch",
    "test": "node --test tests/unit/*.test.js"
  },
  "dependencies": {
    "@xhayper/discord-rpc": "^1.3.3",
    "express": "^4.18.2",
    "helmet": "^8.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0"
  },
  "build": {
    "appId": "com.pete.tracklistplayer",
    "productName": "Tracklist Player",
    "mac": {
      "category": "public.app-category.music",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Audio"
    },
    "files": [
      "electron/**/*",
      "lib/**/*",
      "routes/**/*",
      "public/**/*",
      "server.js",
      "package.json"
    ],
    "extraResources": [],
    "extends": null
  }
}
