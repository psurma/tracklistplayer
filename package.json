{
  "name": "tracklistplayer",
  "version": "1.17.4",
  "description": "DJ mix MP3 player with CUE sheet track detection and Spotify search",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.pete.tracklistplayer",
    "productName": "Tracklist Player",
    "mac": {
      "category": "public.app-category.music",
      "icon": "build/icon.icns",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "category": "Audio"
    },
    "files": [
      "electron/**/*",
      "lib/**/*",
      "public/**/*",
      "server.js",
      "package.json"
    ],
    "extraResources": [],
    "extends": null
  }
}
